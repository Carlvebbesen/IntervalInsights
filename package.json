{
  "name": "interval-insights",
  "scripts": {
    "dev": "bun run --hot --preload ./src/instrumentation.ts src/index.ts | pino-pretty",
    "start": "bun run --preload ./src/instrumentation.ts src/index.ts",
    "test": "bash scripts/test.sh",
    "check": "bash scripts/check.sh",
    "test:pace": "bash scripts/test-pace.sh",
    "test:bun": "bun test",
    "build": "bun build src/index.ts --compile --outfile server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "scripts:run": "bun run scripts/run_pending.ts",
    "brain:sync": "rm -rf knowledge/brain && mkdir -p knowledge && cp -R ../interval-brain/brain knowledge/brain && rm -rf knowledge/brain/_templates && rm -f knowledge/brain/log.md"
  },
  "dependencies": {
    "@clerk/backend": "^2.29.0",
    "@clerk/mcp-tools": "^0.5.0",
    "@hono/clerk-auth": "^3.0.3",
    "@hono/mcp": "^0.3.0",
    "@hono/otel": "^1.1.2",
    "@hono/standard-validator": "^0.2.2",
    "@hono/structured-logger": "^0.1.0",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.7.6",
    "@langchain/core": "^1.1.38",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.217.0",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/instrumentation-pino": "^0.63.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.217.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.3",
    "hono-openapi": "^1.3.0",
    "langchain": "^1.0.0-alpha.6",
    "langsmith": "^0.6.3",
    "marked": "^18.0.5",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "zod": "^3.25.76",
    "zod-openapi": "^4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.1.3"
  }
}
